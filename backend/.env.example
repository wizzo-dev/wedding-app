NODE_ENV=development
PORT=3001

# Database
DB_URL=mysql://wedding_user:password@localhost:3306/wedding_app
DB_ROOT_PASS=rootpassword
DB_USER=wedding_user
DB_PASS=password

# Redis
REDIS_URL=redis://:redispassword@localhost:6379
REDIS_PASS=redispassword

# JWT - CHANGE THESE! (use: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHARS_MIN
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# WhatsApp sessions encryption (use: openssl rand -hex 32)
WA_SESSION_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX
WA_SESSIONS_DIR=./sessions
MAX_WA_SESSIONS=50
# Optional: override Chrome/Chromium path used by whatsapp-web.js (Puppeteer)
# If unset, common system locations are auto-detected.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Internal worker secret (use: openssl rand -hex 32)
INTERNAL_WORKER_SECRET=CHANGE_ME

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@weddingapp.com

# Storage (Cloudflare R2 or S3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=wedding-app
R2_PUBLIC_URL=

# App
APP_URL=http://localhost:3001
